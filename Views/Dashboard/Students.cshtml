@model IEnumerable<ElMaherQuranSchool.Models.Student>
@{
    ViewData["Title"] = "الطلاب";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="card">
    <div style="display:flex; justify-content: space-between; align-items: center; margin-bottom: 24px; flex-wrap:wrap; gap:10px;">
        <h3 style="margin: 0; color: var(--gold);">قائمة الطلاب المسجلين</h3>
        <a href="/Dashboard/AddStudent" class="btn">➕ إضافة طالب</a>
    </div>

    <div class="table-responsive">
        <table>
            <thead>
                <tr>
                    <th>الرقم التسلسلي</th>
                    <th>اسم الطالب</th>
                    <th>إجمالي الأوجه</th>
                    <th>الحلقة</th>
                    <th>تاريخ التسجيل</th>
                    <th>إجراءات</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var student in Model)
                {
                    <tr>
                        <td><span style="background:var(--beige-dark); padding:4px 8px; border-radius:4px; font-weight:bold;">@student.SerialNumber</span></td>
                        <td>@student.Name</td>
                        <td>@student.TotalMemorizedPages أوجه</td>
                        <td>
                            @if(student.Halaqa != null) 
                            { 
                                <span style="background:var(--gold-pale); color:var(--gold); padding:4px 10px; border-radius:50px; font-size:.85rem; font-weight:bold;">@student.Halaqa.Name</span> 
                            } 
                            else 
                            { 
                                <span style="color:var(--text-soft);">غير مسجل</span> 
                            }
                        </td>
                        <td style="font-size: .9rem;">@student.CreatedAt.ToString("yyyy/MM/dd")</td>
                        <td>
                            <div style="display:flex; gap:10px; align-items:center;">
                                <a href="/Dashboard/StudentProgress/@student.Id" style="color:#2196F3; text-decoration:none; font-weight:bold;">المتابعة</a>
                                <a href="/Dashboard/EditStudent/@student.Id" style="color:black; text-decoration:none; font-weight:bold;">✏️ تعديل</a>
                                <form method="post" action="/Dashboard/DeleteStudent" style="display:inline;" onsubmit="return confirmDelete(this, 'هل أنت متأكد من حذف هذا الطالب؟ سيتم حذف جميع بياناته وسجلات حضوره بشكل نهائي.')">
                                    <input type="hidden" name="id" value="@student.Id" />
                                    <button type="submit" style="background:none; border:none; color:#f44336; font-weight:bold; cursor:pointer; padding:0; font-family:inherit; font-size:inherit;">حذف</button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
        
        @if(!Model.Any())
        {
            <div style="text-align:center; padding: 40px 20px; color:var(--text-soft);">
                لا يوجد طلاب مسجلين حالياً.
            </div>
        }
    </div>
</div>

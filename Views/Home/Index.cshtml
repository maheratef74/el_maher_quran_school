@{
    ViewData["Title"] = "Home Page";
    Layout = null;
}

<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>مدرسة الماهر بالقرآن</title>
<link rel="preconnect" href="https://fonts.googleapis.com"/>
<link href="https://fonts.googleapis.com/css2?family=Tajawal:wght@300;400;500;700;800;900&display=swap" rel="stylesheet"/>
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<style>
:root{
  --gold:#357434; /* New Main Color */
  --gold-light:#4a8a49; /* Adjusted Light Version */
  --gold-pale:#e8f0ed; /* Zaity Pale */
  --accent-gold:#b8962e; /* Original Gold for accents */
  --beige:#fafaf7;
  --beige-dark:#e8edea;
  --white:#ffffff;
  --text-dark:#1a2b24;
  --text-mid:#3d5248;
  --text-soft:#5c7368;
  --shadow:0 4px 24px rgba(45,74,62,.1);
  --radius:16px;
  --radius-sm:10px;
}
*{margin:0;padding:0;box-sizing:border-box;}
html{scroll-behavior:smooth;}
body{font-family:'Tajawal',sans-serif;background:var(--beige);color:var(--text-dark);direction:rtl;}

/* ===== SCROLLBAR ===== */
::-webkit-scrollbar{width:6px;}
::-webkit-scrollbar-track{background:var(--beige-dark);}
::-webkit-scrollbar-thumb{background:var(--gold-light);border-radius:3px;}

/* ===== PATTERN BG ===== */
.pattern-bg{
  background-image:url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%23b8962e' fill-opacity='0.06'%3E%3Cpath d='M30 0l30 30-30 30L0 30z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E");
}

/* ===== HERO BG IMAGE ===== */
#hero{
  background-image:
    linear-gradient(to bottom, rgba(232,240,237,0.88) 0%, rgba(232,240,237,0.75) 50%, rgba(232,240,237,0.95) 100%),
    url('https://sedrahedu.com/wp-content/uploads/2024/07/%D9%85%D8%AF%D9%88%D9%86%D8%A9-%D8%AA%D8%B9%D9%84%D9%8A%D9%85-%D8%A7%D9%84%D8%B1%D8%B6%D9%8A%D8%B9-%D8%A7%D9%84%D9%82%D8%B1%D8%A2%D9%86-%D8%A8%D8%A7%D9%84%D8%B3%D9%85%D8%B93-02.webp');
  background-size:cover;
  background-position:center 30%;
  background-attachment:fixed;
}

/* ===== NAVBAR ===== */
#navbar{
  position:fixed;top:0;right:0;left:0;z-index:1000;
  background:rgba(255,252,245,.97);
  backdrop-filter:blur(8px);
  border-bottom:2px solid var(--gold-pale);
  transition:box-shadow .3s;
}
#navbar.scrolled{box-shadow:0 2px 20px rgba(184,150,46,.18);}
.nav-inner{
  max-width:1400px;margin:0 auto;
  display:flex;align-items:center;justify-content:space-between;
  padding:0 20px;height:70px;
}
.nav-logo{
  display:flex;align-items:center;gap:10px;
  font-size:1.1rem;font-weight:900;color:var(--gold);
  text-decoration:none;white-space:nowrap;
}
.nav-logo .logo-icon{
  width:42px;height:42px;background:linear-gradient(135deg,var(--gold),var(--gold-light));
  border-radius:50%;display:flex;align-items:center;justify-content:center;
  font-size:1.3rem;color:#fff;flex-shrink:0;
}
.nav-links{
  display:flex;align-items:center;gap:2px;flex-wrap:nowrap;
  list-style:none;overflow-x:auto;
}
.nav-links a{
  text-decoration:none;color:var(--text-mid);
  font-size:.82rem;font-weight:500;
  padding:6px 10px;border-radius:8px;
  transition:all .25s;white-space:nowrap;
}
.nav-links a:hover,.nav-links a.active{
  color:var(--gold);background:var(--gold-pale);
}
.hamburger{
  display:none;background:none;border:none;
  cursor:pointer;padding:6px;
}
.hamburger span{
  display:block;width:24px;height:2px;background:var(--gold);
  margin:5px 0;transition:.3s;border-radius:2px;
}
.mobile-menu{
  display:none;
  background:var(--white);
  border-top:1px solid var(--gold-pale);
  padding:10px 0;
}
.mobile-menu.open{display:block;}
.mobile-menu a{
  display:block;padding:12px 24px;
  color:var(--text-mid);text-decoration:none;
  font-size:.95rem;font-weight:500;
  border-bottom:1px solid var(--gold-pale);
  transition:.2s;
}
.mobile-menu a:hover{color:var(--gold);background:var(--gold-pale);}

/* ===== HERO ===== */
#hero{
  min-height:100vh;
  display:flex;align-items:center;justify-content:center;
  padding:100px 20px 60px;
  position:relative;overflow:hidden;
}
.hero-ornament{
  position:absolute;
  border-radius:50%;
  background:radial-gradient(circle,rgba(184,150,46,.12),transparent 70%);
}
.hero-ornament-1{width:500px;height:500px;top:-100px;left:-100px;}
.hero-ornament-2{width:400px;height:400px;bottom:-80px;right:-80px;}
.hero-content{text-align:center;position:relative;z-index:1;max-width:800px;}
.hero-badge{
  display:inline-block;
  background:var(--gold-pale);border:1.5px solid var(--gold-light);
  color:var(--gold);border-radius:50px;
  padding:6px 20px;font-size:.85rem;font-weight:700;
  margin-bottom:24px;
  animation:fadeDown .8s ease both;
}
.hero-title{
  font-size:clamp(2.5rem,6vw,4.2rem);
  font-weight:900;color:var(--text-dark);
  line-height:1.2;margin-bottom:16px;
  animation:fadeDown .9s ease .1s both;
}
.hero-title span{color:var(--gold);}
.hero-subtitle{
  font-size:clamp(.95rem,2vw,1.2rem);
  color:var(--text-mid);line-height:1.8;
  margin-bottom:36px;
  animation:fadeDown 1s ease .2s both;
}
.hero-btns{
  display:flex;gap:14px;justify-content:center;flex-wrap:wrap;
  animation:fadeDown 1s ease .3s both;
}
.btn-gold{
  background:linear-gradient(135deg,var(--gold),var(--gold-light));
  color:#fff;border:none;border-radius:50px;
  padding:14px 32px;font-size:1rem;font-weight:700;
  font-family:'Tajawal',sans-serif;
  cursor:pointer;transition:.3s;box-shadow:0 4px 18px rgba(184,150,46,.35);
  text-decoration:none;display:inline-block;
}
.btn-gold:hover{transform:translateY(-2px);box-shadow:0 8px 28px rgba(184,150,46,.45);}
.btn-outline{
  background:transparent;color:var(--gold);
  border:2px solid var(--gold);border-radius:50px;
  padding:13px 32px;font-size:1rem;font-weight:700;
  font-family:'Tajawal',sans-serif;
  cursor:pointer;transition:.3s;
  text-decoration:none;display:inline-block;
}
.btn-outline:hover{background:var(--gold-pale);}

/* ===== STATS ===== */
.stats-bar{
  background:linear-gradient(135deg,#1a2b24,var(--gold));
  padding:40px 20px;
}
.stats-inner{
  max-width:900px;margin:0 auto;
  display:grid;grid-template-columns:repeat(auto-fit,minmax(200px,1fr));gap:20px;
}
.stat-item{text-align:center;color:#fff;}
.stat-num{font-size:2.5rem;font-weight:900;display:block;}
.stat-label{font-size:.95rem;opacity:.9;margin-top:4px;}

/* ===== SECTIONS ===== */
section{padding:80px 20px;}
.section-inner{max-width:1100px;margin:0 auto;}
.section-header{text-align:center;margin-bottom:50px;}
.section-tag{
  display:inline-block;
  background:var(--gold-pale);color:var(--gold);
  border-radius:50px;padding:4px 18px;
  font-size:.82rem;font-weight:700;margin-bottom:14px;
}
.section-title{
  font-size:clamp(1.8rem,4vw,2.6rem);
  font-weight:900;color:var(--text-dark);margin-bottom:12px;
}
.section-line{
  width:60px;height:3px;
  background:linear-gradient(90deg,var(--gold),var(--accent-gold));
  border-radius:2px;margin:0 auto;
}

/* ===== CARDS ===== */
.card{
  background:var(--white);border-radius:var(--radius);
  box-shadow:var(--shadow);padding:28px;
  border:1px solid rgba(184,150,46,.1);
  transition:.3s;
}
.card:hover{transform:translateY(-4px);box-shadow:0 12px 36px rgba(184,150,46,.18);}
.grid-3{display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:24px;}
.grid-2{display:grid;grid-template-columns:repeat(auto-fit,minmax(320px,1fr));gap:24px;}
.grid-4{display:grid;grid-template-columns:repeat(auto-fit,minmax(220px,1fr));gap:20px;}
.card-icon{
  width:52px;height:52px;border-radius:14px;
  background:linear-gradient(135deg,var(--gold-pale),#fff);
  border:2px solid var(--gold-pale);
  display:flex;align-items:center;justify-content:center;
  font-size:1.5rem;margin-bottom:16px;
}
.card-title{font-size:1.3rem;font-weight:800;color:var(--text-dark);margin-bottom:8px;}
.card-text{font-size:.9rem;color:var(--text-soft);line-height:1.8;}

/* ===== VALUES PYRAMID ===== */
.values-pyramid {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 15px;
  margin-top: 30px;
}
.pyramid-row {
  display: flex;
  justify-content: center;
  gap: 15px;
  width: 100%;
}
.value-card {
  background: var(--white);
  padding: 18px 24px;
  border-radius: 12px;
  box-shadow: 0 4px 12px rgba(45,74,62,0.08);
  border: 1px solid var(--gold-pale);
  text-align: center;
  transition: all 0.3s ease;
  flex: 0 1 210px;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8px;
}
.value-card:hover {
  transform: translateY(-5px);
  border-color: var(--gold);
  box-shadow: 0 8px 24px rgba(45,74,62,0.15);
}
.value-icon {
  font-size: 1.8rem;
}
.value-title {
  font-weight: 800;
  color: var(--gold);
  font-size: 0.95rem;
}
@@media (max-width: 900px) {
  .pyramid-row {
    flex-wrap: wrap;
    gap: 10px;
  }
  .value-card {
    flex: 1 1 calc(50% - 10px);
    padding: 14px;
  }
}
@@media (max-width: 500px) {
  .value-card {
    flex: 1 1 100%;
  }
}

/* ===== ABOUT ===== */
#about{background:var(--white);}
.about-intro{
  background:linear-gradient(135deg,var(--gold-pale),#fffcf5);
  border-radius:var(--radius);padding:36px;
  border:1px solid rgba(184,150,46,.15);
  margin-bottom:40px;text-align:center;
}
.about-intro p{font-size:1.05rem;color:var(--text-mid);line-height:2;}

/* ===== FOLLOW CHILDREN ===== */
#follow{background:var(--beige);}
.follow-box{
  background:var(--white);border-radius:var(--radius);
  box-shadow:var(--shadow);padding:40px;
  max-width:700px;margin:0 auto;
}
.input-group{display:flex;gap:12px;margin-bottom:24px;flex-wrap:wrap;}
.input-group input{
  flex:1;min-width:200px;
  border:2px solid var(--gold-pale);border-radius:50px;
  padding:14px 22px;font-size:1rem;font-family:'Tajawal',sans-serif;
  color:var(--text-dark);background:var(--beige);
  outline:none;transition:.3s;
  text-align:right;
}
.input-group input:focus{border-color:var(--gold);background:#fff;}
.halaqat-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(180px,1fr));gap:14px;margin-top:20px;}
.halaqa-card{
  background:var(--white);border:2px solid var(--gold-pale);
  border-radius:var(--radius-sm);padding:18px;text-align:center;
  cursor:pointer;transition:.3s;
}
.halaqa-card:hover,.halaqa-card.selected{
  border-color:var(--gold);background:var(--gold-pale);
}
.halaqa-name{font-weight:800;color:var(--text-dark);margin-bottom:4px;}
.halaqa-count{font-size:.82rem;color:var(--text-soft);}
.students-table{width:100%;border-collapse:collapse;margin-top:20px;}
.students-table th{
  background:var(--gold-pale);color:var(--gold);
  padding:12px 16px;font-size:.9rem;font-weight:700;
  text-align:right;border-bottom:2px solid var(--gold-light);
}
.students-table td{
  padding:12px 16px;font-size:.9rem;
  border-bottom:1px solid var(--beige-dark);color:var(--text-mid);
}
.students-table tr.my-child td{
  background:linear-gradient(90deg,rgba(184,150,46,.08),transparent);
  font-weight:700;color:var(--text-dark);
}
.students-table tr:hover td{background:var(--beige);}
.rank-badge{
  display:inline-flex;align-items:center;justify-content:center;
  width:30px;height:30px;border-radius:50%;
  font-weight:900;font-size:.85rem;
}
.rank-1{background:linear-gradient(135deg,#ffd700,#ffb300);color:#fff;}
.rank-2{background:linear-gradient(135deg,#c0c0c0,#9e9e9e);color:#fff;}
.rank-3{background:linear-gradient(135deg,#cd7f32,#a0522d);color:#fff;}
.rank-other{background:var(--beige-dark);color:var(--text-soft);}
.student-row{cursor:pointer;}
.star-badge{color:var(--gold);margin-right:6px;}
.hidden{display:none!important;}
.step-title{
  font-size:1.2rem;font-weight:800;color:var(--gold);
  margin-bottom:14px;padding-bottom:10px;
  border-bottom:2px solid var(--gold-pale);
}

/* ===== MODAL ===== */
.modal-overlay{
  position:fixed;inset:0;
  background:rgba(44,36,22,.6);backdrop-filter:blur(4px);
  z-index:2000;display:flex;align-items:center;justify-content:center;
  padding:20px;opacity:0;pointer-events:none;transition:.35s;
}
.modal-overlay.open{opacity:1;pointer-events:all;}
.modal-box{
  background:var(--white);border-radius:20px;
  max-width:700px;width:100%;max-height:90vh;overflow-y:auto;
  box-shadow:0 20px 60px rgba(44,36,22,.25);
  transform:translateY(30px) scale(.97);transition:.35s;
}
.modal-overlay.open .modal-box{transform:none;}
.modal-header{
  background:linear-gradient(135deg,var(--gold),var(--gold-light));
  padding:28px 32px;border-radius:20px 20px 0 0;
  display:flex;align-items:center;justify-content:space-between;
}
.modal-header h2{color:#fff;font-size:1.6rem;font-weight:900;}
.modal-close{
  background:rgba(255,255,255,.25);border:none;
  color:#fff;width:36px;height:36px;border-radius:50%;
  cursor:pointer;font-size:1.1rem;transition:.2s;
  display:flex;align-items:center;justify-content:center;
}
.modal-close:hover{background:rgba(255,255,255,.4);}
.modal-body{padding:28px 32px;}
.modal-student-info{
  display:flex;align-items:center;gap:20px;
  margin-bottom:24px;flex-wrap:wrap;
}
.modal-avatar{
  width:64px;height:64px;border-radius:50%;
  background:linear-gradient(135deg,var(--gold-pale),#fff);
  border:3px solid var(--gold-light);
  display:flex;align-items:center;justify-content:center;
  font-size:1.8rem;flex-shrink:0;
}
.modal-name{font-size:1.5rem;font-weight:900;color:var(--text-dark);}
.modal-rank{font-size:.9rem;color:var(--text-soft);margin-top:4px;}
.medal-badge{
  display:inline-flex;align-items:center;gap:6px;
  background:linear-gradient(135deg,var(--gold-pale),#fff);
  border:2px solid var(--gold-light);
  border-radius:50px;padding:6px 16px;
  color:var(--gold);font-weight:800;font-size:.88rem;
  margin-top:8px;
}
.progress-wrap{margin-bottom:24px;}
.progress-label{
  display:flex;justify-content:space-between;
  font-size:.88rem;color:var(--text-mid);margin-bottom:8px;font-weight:600;
}
.progress-bar-bg{
  background:var(--beige-dark);border-radius:50px;height:12px;overflow:hidden;
}
.progress-bar-fill{
  height:100%;border-radius:50px;
  background:linear-gradient(90deg,var(--gold),var(--gold-light));
  transition:width 1s ease;
}
.modal-section{margin-bottom:24px;}
.modal-section h4{
  font-size:.95rem;font-weight:800;color:var(--gold);
  margin-bottom:12px;padding-bottom:8px;
  border-bottom:1px solid var(--gold-pale);
}
.data-table{width:100%;border-collapse:collapse;font-size:.88rem;}
.data-table th{
  background:var(--beige);color:var(--text-mid);
  padding:10px 14px;text-align:right;
  font-weight:700;border-bottom:2px solid var(--gold-pale);
}
.data-table td{
  padding:10px 14px;border-bottom:1px solid var(--beige-dark);
  color:var(--text-dark);
}
.data-table tr:hover td{background:var(--beige);}
.attendance-dot{
  display:inline-block;width:10px;height:10px;border-radius:50%;margin-left:4px;
}
.dot-present{background:#4caf50;}
.dot-absent{background:#f44336;}
.note-box{
  background:var(--gold-pale);border-radius:var(--radius-sm);
  padding:18px;font-size:.9rem;color:var(--text-mid);line-height:1.8;
  border-right:4px solid var(--gold);
}
.chart-wrap{position:relative;height:200px;margin-bottom:10px;}

/* ===== CAMPS ===== */
#camps{background:var(--white);}
.camp-card{
  border-radius:var(--radius);overflow:hidden;
  box-shadow:var(--shadow);border:1px solid rgba(184,150,46,.1);
  transition:.3s;
}
.camp-card:hover{transform:translateY(-4px);box-shadow:0 12px 36px rgba(184,150,46,.2);}
.camp-img{
  height:200px;
  background:linear-gradient(135deg,var(--gold-pale),#f0d898);
  display:flex;align-items:center;justify-content:center;
  font-size:3.5rem;
  overflow:hidden;position:relative;
}
.camp-img img{
  width:100%;height:100%;object-fit:cover;
  transition:transform .5s ease;
  display:block;
}
.camp-card:hover .camp-img img{transform:scale(1.06);}
.camp-img-overlay{
  position:absolute;inset:0;
  background:linear-gradient(to bottom, rgba(44,36,22,0) 40%, rgba(44,36,22,0.22) 100%);
}
.camp-info{padding:22px;}
.camp-date{
  display:inline-block;background:var(--gold-pale);
  color:var(--gold);border-radius:50px;
  padding:3px 12px;font-size:.78rem;font-weight:700;margin-bottom:10px;
}
.camp-title{font-size:1.2rem;font-weight:800;color:var(--text-dark);margin-bottom:6px;}
.camp-desc{font-size:.88rem;color:var(--text-soft);line-height:1.7;}

/* ===== ACTIVITIES ===== */
#activities{background:var(--beige);}
.gallery-grid{
  display:grid;
  grid-template-columns:repeat(auto-fill,minmax(240px,1fr));
  gap:18px;
}
.gallery-item{
  border-radius:var(--radius);overflow:hidden;
  position:relative;box-shadow:var(--shadow);cursor:pointer;
}
.gallery-thumb{
  height:200px;
  background:linear-gradient(135deg,var(--gold-pale),#e8d08a);
  display:flex;align-items:center;justify-content:center;
  font-size:3rem;transition:.4s;
  overflow:hidden;position:relative;
}
.gallery-thumb img{
  width:100%;height:100%;object-fit:cover;
  transition:transform .5s ease;display:block;
}
.gallery-item:hover .gallery-thumb img{transform:scale(1.08);}
.gallery-thumb-overlay{
  position:absolute;inset:0;
  background:linear-gradient(to bottom,transparent 50%,rgba(44,36,22,0.3));
}
.gallery-caption{
  background:var(--white);padding:14px 18px;
  font-size:.9rem;font-weight:700;color:var(--text-dark);
}

/* ===== EVENTS ===== */
#events{background:var(--white);}

/* ===== NOORANIYA ===== */
#nooraniya{background:var(--beige);}
.steps-list{display:flex;flex-direction:column;gap:18px;max-width:700px;margin:0 auto;}
.step-item{
  display:flex;align-items:flex-start;gap:18px;
  background:var(--white);border-radius:var(--radius-sm);
  padding:22px;box-shadow:var(--shadow);
  border:1px solid rgba(184,150,46,.1);
}
.step-num{
  width:42px;height:42px;flex-shrink:0;
  background:linear-gradient(135deg,var(--gold),var(--gold-light));
  border-radius:50%;color:#fff;font-weight:900;font-size:1rem;
  display:flex;align-items:center;justify-content:center;
}

/* ===== COURSES ===== */
#courses{background:var(--white);}
.course-card{position:relative;}
.course-level{
  display:inline-block;background:var(--gold-pale);color:var(--gold);
  border-radius:50px;padding:3px 12px;font-size:.75rem;font-weight:700;
  margin-bottom:10px;
}
.course-duration{
  display:flex;align-items:center;gap:6px;
  font-size:.82rem;color:var(--text-soft);margin-top:10px;
}

/* ===== KNOWLEDGE ===== */
#knowledge{background:var(--beige);}
.knowledge-card{
  display:flex;flex-direction:column;align-items:center;
  text-align:center;gap:14px;
}
.k-icon{
  width:64px;height:64px;
  background:linear-gradient(135deg,var(--gold-pale),#fff);
  border:2px solid var(--gold-pale);border-radius:18px;
  display:flex;align-items:center;justify-content:center;
  font-size:1.8rem;
}
.k-items{display:flex;flex-direction:column;gap:8px;width:100%;margin-top:8px;}
.k-link{
  background:var(--beige);border-radius:8px;padding:10px 14px;
  color:var(--text-mid);font-size:.88rem;font-weight:600;
  text-decoration:none;transition:.2s;
  border:1px solid var(--gold-pale);
  display:flex;justify-content:space-between;align-items:center;
}
.k-link:hover{background:var(--gold-pale);color:var(--gold);}

/* ===== YOUTUBE ===== */
#youtube{background:var(--white);}
.yt-wrap{
  max-width:800px;margin:0 auto;
  background:var(--text-dark);border-radius:var(--radius);
  overflow:hidden;box-shadow:0 12px 40px rgba(44,36,22,.25);
}
.yt-wrap iframe{width:100%;height:400px;display:block;border:none;}
.yt-info{
  background:var(--text-dark);padding:20px 28px;
  color:#fff;display:flex;align-items:center;gap:14px;
}
.yt-logo{font-size:1.8rem;}
.yt-channel{font-weight:800;font-size:1rem;}
.yt-subs{font-size:.82rem;color:rgba(255,255,255,.6);}
.yt-btn{
  margin-right:auto;background:#ff0000;color:#fff;
  border:none;border-radius:50px;padding:8px 20px;
  font-family:'Tajawal',sans-serif;font-weight:700;font-size:.88rem;
  cursor:pointer;transition:.2s;
}
.yt-btn:hover{background:#cc0000;}

/* ===== REGISTRATION ===== */
#register{background:var(--beige);}
.reg-form{
  max-width:580px;margin:0 auto;
  background:var(--white);border-radius:var(--radius);
  box-shadow:var(--shadow);padding:40px;
}
.form-group{margin-bottom:20px;}
.form-group label{
  display:block;font-size:.9rem;font-weight:700;
  color:var(--text-dark);margin-bottom:8px;
}
.form-group input,.form-group select{
  width:100%;
  border:2px solid var(--beige-dark);border-radius:var(--radius-sm);
  padding:13px 16px;font-size:.95rem;font-family:'Tajawal',sans-serif;
  color:var(--text-dark);background:var(--beige);
  outline:none;transition:.3s;text-align:right;
}
.form-group input:focus,.form-group select:focus{
  border-color:var(--gold);background:#fff;
}
.form-grid{display:grid;grid-template-columns:1fr 1fr;gap:16px;}

/* ===== TEACHERS ===== */
#teachers{background:var(--white);}
.teacher-card{text-align:center;}
.teacher-avatar{
  width:100px;height:100px;border-radius:50%;
  background-color:var(--gold-pale);
  background-image: url('/image/pngtree-a-veiled-teacher-in-gray-shirt-image_6717646.png');
  background-size: 280%;
  background-position: center 2%;
  border:4px solid var(--gold-light);
  display:flex;align-items:center;justify-content:center;
  margin:0 auto 16px;
  overflow: hidden;
}
.teacher-name{font-size:1.05rem;font-weight:800;color:var(--text-dark);margin-bottom:6px;}
.teacher-title{
  display:inline-block;background:var(--gold-pale);color:var(--gold);
  border-radius:50px;padding:3px 14px;font-size:.78rem;font-weight:700;
  margin-bottom:10px;
}

/* ===== FAQ ===== */
#faq{background:var(--beige);}
.faq-list{max-width:700px;margin:0 auto;display:flex;flex-direction:column;gap:12px;}
.faq-item{
  background:var(--white);border-radius:var(--radius-sm);
  box-shadow:var(--shadow);border:1px solid rgba(184,150,46,.1);
  overflow:hidden;
}
.faq-q{
  width:100%;background:none;border:none;text-align:right;
  padding:18px 22px;font-family:'Tajawal',sans-serif;
  font-size:.95rem;font-weight:700;color:var(--text-dark);
  cursor:pointer;display:flex;justify-content:space-between;align-items:center;
  transition:.2s;
}
.faq-q:hover{background:var(--gold-pale);}
.faq-icon{
  width:24px;height:24px;border-radius:50%;
  background:var(--gold-pale);color:var(--gold);
  display:flex;align-items:center;justify-content:center;
  font-size:.9rem;flex-shrink:0;transition:.3s;margin-right:8px;
}
.faq-item.open .faq-icon{transform:rotate(45deg);background:var(--gold);color:#fff;}
.faq-a{
  max-height:0;overflow:hidden;transition:.35s ease;
}
.faq-item.open .faq-a{max-height:200px;}
.faq-a-inner{
  padding:0 22px 18px;
  font-size:.9rem;color:var(--text-soft);line-height:1.8;
}

/* ===== CONTACT ===== */
#contact{background:var(--white);}
.contact-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(240px,1fr));gap:24px;max-width:800px;margin:0 auto;}
.contact-item{
  text-align:center;background:var(--beige);
  border-radius:var(--radius);padding:32px 24px;
  border:1px solid var(--gold-pale);
}
.contact-icon{font-size:2rem;margin-bottom:14px;}
.contact-label{font-size:.85rem;color:var(--text-soft);font-weight:600;margin-bottom:6px;}
.contact-val{font-size:1rem;font-weight:800;color:var(--text-dark);}
.wa-btn{
  display:inline-flex;align-items:center;gap:8px;
  background:#25d366;color:#fff;border-radius:50px;
  padding:12px 28px;font-size:.95rem;font-weight:700;
  text-decoration:none;transition:.3s;margin-top:10px;
  font-family:'Tajawal',sans-serif;border:none;cursor:pointer;
}
.wa-btn:hover{background:#1ebe5a;}

/* ===== STICKY WHATSAPP ===== */
#stickyWA {
  position: fixed;
  bottom: 90px;
  right: 25px;
  z-index: 1000;
  width: 60px;
  height: 60px;
  background-color: #25d366;
  color: #fff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32px;
  box-shadow: 0 4px 15px rgba(0,0,0,0.2);
  text-decoration: none;
  transition: transform 0.3s ease, background-color 0.3s ease;
  animation: waBounce 2s infinite;
}
#stickyWA:hover {
  transform: scale(1.1);
  background-color: #1ebe5a;
}
@@keyframes waBounce {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-5px); }
}

/* ===== MAP STYLE ===== */
.map-container {
  width: 100%;
  height: 400px;
  border-radius: var(--radius);
  overflow: hidden;
  margin-top: 30px;
  box-shadow: var(--shadow);
}
.map-container iframe {
  width: 100%;
  height: 100%;
  border: 0;
}

/* ===== FOOTER ===== */
footer{
  background:var(--text-dark);color:rgba(255,255,255,.8);
  padding:40px 20px 24px;text-align:center;
}
.footer-logo{
  font-size:1.2rem;font-weight:900;color:var(--gold-light);margin-bottom:14px;
}
.footer-links{
  display:flex;justify-content:center;flex-wrap:wrap;gap:8px;
  list-style:none;margin-bottom:24px;
}
.footer-links a{color:rgba(255,255,255,.6);text-decoration:none;font-size:.82rem;transition:.2s;}
.footer-links a:hover{color:var(--gold-light);}
.footer-sep{color:rgba(255,255,255,.2);}
.footer-copy{font-size:.8rem;color:rgba(255,255,255,.4);}

/* ===== ANIMATIONS ===== */
@@keyframes fadeDown{
  from{opacity:0;transform:translateY(-18px);}
  to{opacity:1;transform:none;}
}
.fade-in{opacity:0;transform:translateY(24px);transition:.7s ease;}
.fade-in.visible{opacity:1;transform:none;}

/* ===== SCROLL TOP ===== */
#scrollTop{
  position:fixed;bottom:93px;left:28px;
  width:44px;height:44px;
  background:linear-gradient(135deg,var(--gold),var(--gold-light));
  color:#fff;border:none;border-radius:50%;
  cursor:pointer;font-size:1.1rem;
  box-shadow:0 4px 18px rgba(184,150,46,.4);
  display:flex;align-items:center;justify-content:center;
  opacity:0;pointer-events:none;transition:.3s;z-index:900;
}
#scrollTop.show{opacity:1;pointer-events:all;}

/* ===== MOBILE ===== */
@@media(max-width:900px){
  .nav-links{display:none;}
  .hamburger{display:block;}
  .form-grid{grid-template-columns:1fr;}
  .modal-body{padding:20px;}
}
@@media(max-width:600px){

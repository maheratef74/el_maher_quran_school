<!-- SCROLL TOP -->
<button id="scrollTop" onclick="window.scrollTo({top:0,behavior:'smooth'})" title="العودة للأعلى">↑</button>

<script>
// ===== DATA Fetching API =====
let currentPhone = "";
let currentHalaqa = null;
let progressChart = null;

let apiParentData = null;

document.addEventListener('DOMContentLoaded', () => {
  const savedPhone = localStorage.getItem('parentPhone');
  if(savedPhone) {
    document.getElementById('phoneInput').value = savedPhone;
  }
});

async function showHalaqat(isAutoLoad = false) {
  const phone = document.getElementById('phoneInput').value.trim();
  if(!phone){
      if(!isAutoLoad) alert('الرجاء إدخال رقم الهاتف'); 
      return;
  }
  currentPhone = phone;
  localStorage.setItem('parentPhone', phone);

  try {
    const res = await fetch('/Home/GetParentData?phone=' + phone);
    const data = await res.json();

    if(!data.success) {
      if(!isAutoLoad) alert('لم يتم العثور على أبناء مسجلين بهذا الرقم.');
      else {
          // If auto-loaded but phone was somehow wrong or deleted from DB, clear it out.
          localStorage.removeItem('parentPhone');
          document.getElementById('phoneInput').value = "";
      }
      return;
    }

    apiParentData = data;

    document.getElementById('step1').classList.add('hidden');
    document.getElementById('step2').classList.remove('hidden');

    const grid = document.getElementById('halaqatGrid');
    grid.innerHTML = '';

    const info = document.createElement('div');
    info.style.cssText = "background:var(--gold-pale);border-radius:10px;padding:14px 18px;margin-bottom:16px;font-size:.9rem;color:var(--text-mid);";
    info.innerHTML = `مرحباً بك <strong>${data.parentName}</strong> 👋`;
    grid.appendChild(info);

    data.halaqat.forEach(h => {
      const div = document.createElement('div');
      div.className = 'halaqa-card';
      div.innerHTML = `<div class="halaqa-name">${h.name}</div><div class="halaqa-count">${h.sheikh}</div><div class="halaqa-count">${h.students.length} طالب بالحلقة</div>`;
      div.onclick = () => showStudents(h, div);
      grid.appendChild(div);
    });
  } catch(e) {
    alert('حدث خطأ أثناء الاتصال بالخادم.');
  }
}

function showStudents(halaqaObj, cardEl) {
  document.querySelectorAll('.halaqa-card').forEach(c => c.classList.remove('selected'));
  if (cardEl) cardEl.classList.add('selected');
  currentHalaqa = halaqaObj.id;
  
  setTimeout(()=>{
    document.getElementById('step2').classList.add('hidden');
    document.getElementById('step3').classList.remove('hidden');
    
    // Sort descending by total pages then pagesProgress
    const sorted = [...halaqaObj.students].sort((a,b) => (b.awjoh + (b.pagesProgress/1000)) - (a.awjoh + (a.pagesProgress/1000)));
    
    const tbody = document.getElementById('studentsBody');
    tbody.innerHTML = '';
    sorted.forEach((s,i) => {
      const rank = i+1;
      let badge = `<div class="rank-badge rank-other">${rank}</div>`;
      if(rank===1) badge = `<div class="rank-badge rank-1">🥇</div>`;
      if(rank===2) badge = `<div class="rank-badge rank-2">🥈</div>`;
      if(rank===3) badge = `<div class="rank-badge rank-3">🥉</div>`;
      
      const tr = document.createElement('tr');
      tr.className = `student-row${s.isMyChild ? ' my-child' : ''}`;
      tr.innerHTML = `<td>${badge}</td><td>${s.isMyChild ? '⭐ ' : ''}<strong>${s.name}</strong></td><td>${s.awjoh} وجهاً</td><td>${s.pagesProgress}</td>`;
      
      if (s.isMyChild) {
        tr.onclick = () => openModal(s, rank);
        tr.style.cursor = 'pointer';
        tr.title = 'اضغط لعرض ملف الطالب وملاحظات المعلم';
      } else {
        tr.style.opacity = '0.7';
        tr.title = 'لا يمكن عرض تفاصيل الطلاب الآخرين لضمان الخصوصية';
      }
      tbody.appendChild(tr);
    });
  }, 200);
}

function backToHalaqat(){
  document.getElementById('step3').classList.add('hidden');
  document.getElementById('step2').classList.remove('hidden');
}

function openModal(student, rank){
  const modal = document.getElementById('studentModal');
  const body = document.getElementById('modalBody');
  document.getElementById('modalTitle').textContent = 'ملف الطالب';
  
  const targetAwjoh = student.targetPages && student.targetPages > 0 ? student.targetPages : 30;
  const pct = Math.round((student.awjoh / targetAwjoh) * 100);
  
  let chartDates = ['اليوم'];
  let chartScores = [0];
  let attendanceRows = `<tr><td colspan="2" style="text-align:center;">لم يسجل حضور بعد</td></tr>`;
  let latestNote = "لا توجد ملاحظات مسجلة بعد.";

  if (student.sessions && student.sessions.length > 0) {
    // Reverse so the oldest is on the left of chart, newest on right
    chartDates = student.sessions.map(r => r.date).reverse();
    chartScores = student.sessions.map(r => r.score).reverse();


    attendanceRows = student.sessions.map(s => {
      return `<tr><td>${s.date}</td><td><span class="attendance-dot ${s.isPresent?'dot-present':'dot-absent'}"></span> ${s.isPresent?'حاضر':'غائب'}</td></tr>`;
    }).join('');

    const noteRecord = student.sessions.find(s => s.note && s.note.trim() !== "");
    if (noteRecord) {
      latestNote = noteRecord.date + ": " + noteRecord.note;
    }
  }
  
  let badgeText = rank===1?'🥇 الطالب الأول':rank===2?'🥈 متفوق':rank===3?'🥉 ممتاز':(student.awjoh>=15?'⭐ حافظ متميز':'📖 طالب مجتهد');
  
  let avatarHtml = `<div class="modal-avatar">📖</div>`;
  if (student.profileImageUrl) {
      // Ensure the URL starts with / if it doesn't already
      let imgUrl = student.profileImageUrl.startsWith('/') ? student.profileImageUrl : '/' + student.profileImageUrl;
      avatarHtml = `<div class="modal-avatar" style="background-image: url('${imgUrl}'); background-size: cover; background-position: center;"></div>`;
  }
  
  body.innerHTML = `
    <div class="modal-student-info">
      ${avatarHtml}
      <div>
        <div class="modal-name">${student.name}</div>
        <div class="modal-rank">الترتيب: #${rank} في الحلقة</div>
        <div class="medal-badge">${badgeText}</div>
      </div>
    </div>
    <div class="progress-wrap">
      <div class="progress-label"><span>تقدم الحفظ</span><span>${student.awjoh}/${targetAwjoh} وجهاً (${pct}%)</span></div>
      <div class="progress-bar-bg"><div class="progress-bar-fill" style="width:0%" id="progFill"></div></div>
    </div>
    <div class="modal-section">
      <h4>📈 منحنى التقييم اليومي (من 100 نقطة)</h4>
      <div class="chart-wrap"><canvas id="progressChart"></canvas></div>
    </div>
    <div class="modal-section">
      <h4>📋 سجل الحضور الحديث</h4>
      <div style="overflow-x:auto;">
        <table class="data-table"><thead><tr><th>التاريخ</th><th>الحالة</th></tr></thead><tbody>${attendanceRows}</tbody></table>
      </div>
    </div>
    <div class="modal-section">
      <h4>📊 إجمالي المؤشرات</h4>
      <div style="overflow-x:auto;">
        <table class="data-table">
          <thead><tr><th>البند</th><th>النسبة والتفاصيل</th></tr></thead>
          <tbody>
            <tr><td>الالتزام بالحضور</td><td><strong style="color:#4CAF50;">${student.attendance}%</strong> حضور فعلي</td></tr>
            <tr><td>إنجاز الأوجه</td><td><strong style="color:var(--gold);">${pct}%</strong> (${student.awjoh} من أصل ${targetAwjoh} وجه)</td></tr>
            <tr><td>إنجاز النقاط</td><td><strong>${student.pagesProgress}</strong> نقطة مكتسبة</td></tr>
            <tr><td>إجمالي التقييم</td><td><strong>${student.pointProgress}</strong> نقطة</td></tr>
          </tbody>
        </table>
      </div>
    </div>
    <div class="modal-section">
      <h4>📝 أحدث ملحوظات المعلم</h4>
      <div class="note-box">${latestNote}</div>
    </div>
  `;
  
  modal.classList.add('open');
  document.body.style.overflow = 'hidden';
  
  setTimeout(()=>{
    const fill = document.getElementById('progFill');
    if(fill) fill.style.width = pct+'%';
    
    const ctx = document.getElementById('progressChart');
    if(ctx){
      if(progressChart) progressChart.destroy();
      progressChart = new Chart(ctx, {
        type:'line',
        data:{
          labels: chartDates,
          datasets:[{
            label:'نقاط الجلسة',
            data: chartScores,
            borderColor:'#b8962e',
            backgroundColor:'rgba(184,150,46,.12)',
            borderWidth:3,
            pointBackgroundColor:'#b8962e',
            pointRadius:5,
            tension:0.4,
            fill:true
          }]
        },
        options:{
          responsive:true,maintainAspectRatio:false,
          plugins:{legend:{display:false}},
          scales:{
            y:{beginAtZero:true, max:100, grid:{color:'rgba(184,150,46,.1)'},ticks:{color:'#8a7355', stepSize:20}},
            x:{grid:{color:'rgba(184,150,46,.1)'},ticks:{color:'#8a7355',font:{family:'Tajawal'}}}
          }
        }
      });
    }
  }, 200);
}

function closeModal(){
  document.getElementById('studentModal').classList.remove('open');
  document.body.style.overflow = '';
}
document.getElementById('studentModal').addEventListener('click',function(e){
  if(e.target===this) closeModal();
});

// ===== FAQ =====
function toggleFaq(btn){
  const item = btn.parentElement;
  const wasOpen = item.classList.contains('open');
  document.querySelectorAll('.faq-item').forEach(f=>f.classList.remove('open'));
  if(!wasOpen) item.classList.add('open');
}

// ===== REGISTRATION =====
function sendWhatsApp(){
  const name = document.getElementById('regName').value.trim();
  const age  = document.getElementById('regAge').value.trim();
  const phone= document.getElementById('regPhone').value.trim();
  const level= document.getElementById('regLevel').value;
  if(!name||!age||!phone||!level){alert('الرجاء تعبئة جميع الحقول');return;}
  const msg = encodeURIComponent(`السلام عليكم 🌹\nأرغب في تسجيل ابني في مدرسة الماهر بالقرآن:\n👤 الاسم: ${name}\n🎂 العمر: ${age} سنوات\n📱 الهاتف: ${phone}\n📚 المستوى: ${level}`);
  window.open(`https://wa.me/201110927230?text=${msg}`,'_blank');
}

// ===== NAVBAR =====
function toggleMenu(){
  document.getElementById('mobileMenu').classList.toggle('open');
}
function closeMobile(){
  document.getElementById('mobileMenu').classList.remove('open');
}
window.addEventListener('scroll',()=>{
  const nav = document.getElementById('navbar');
  const top = document.getElementById('scrollTop');
  nav.classList.toggle('scrolled', window.scrollY>30);
  top.classList.toggle('show', window.scrollY>300);
});

// ===== COUNTER ANIMATION =====
function animateCounters(){
  document.querySelectorAll('[data-count]').forEach(el=>{
    const target = +el.dataset.count;
    let current = 0;
    const step = Math.ceil(target/60);
    const timer = setInterval(()=>{
      current = Math.min(current+step, target);
      el.textContent = current.toLocaleString('ar-SA');
      if(current>=target) clearInterval(timer);
    },25);
  });
}

// ===== SCROLL ANIMATIONS =====
const observer = new IntersectionObserver((entries)=>{
  entries.forEach(e=>{
    if(e.isIntersecting){
      e.target.classList.add('visible');
      if(e.target.querySelector('[data-count]')){
        animateCounters();
      }
    }
  });
},{threshold:.12});
document.querySelectorAll('.fade-in').forEach(el=>observer.observe(el));

// ===== ACTIVE NAV =====
const sections = document.querySelectorAll('section[id], div.stats-bar[id]');
const navLinks = document.querySelectorAll('.nav-links a');
window.addEventListener('scroll',()=>{
  let current='';
  document.querySelectorAll('section[id]').forEach(sec=>{
    if(window.scrollY>=sec.offsetTop-120) current=sec.id;
  });
  navLinks.forEach(a=>{
    a.classList.remove('active');
    if(a.getAttribute('href')==='#'+current) a.classList.add('active');
  });
},{ passive:true });
</script>
